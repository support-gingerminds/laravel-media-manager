{
    "name": "gingerminds/laravel-media-manager",
    "description": "Media Manager functionalities for Laravel projects",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Gingerminds\\LaravelMediaManager\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Gingerminds"
        }
    ],
    "require": {
        "php": "^8.3",
        "gingerminds/laravel-core": "^2.4 || dev-develop",
        "league/glide": "^4.0",
      "ext-zip": "*"
    },
    "require-dev": {
        "larastan/larastan": "^3.8",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^2.0",
        "phpdocumentor/type-resolver": "^1.8"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gingerminds\\LaravelMediaManager\\Providers\\LaravelMediaManagerServiceProvider"
            ]
        }
    }
}
